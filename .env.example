# ===== AI Provider 설정 =====
# 사용할 provider: anthropic | openai | gemini
AI_PROVIDER=anthropic
# 모델명 (비워두면 provider 기본값 사용)
# anthropic 기본값: claude-opus-4-6
# openai    기본값: gpt-4o
# gemini    기본값: gemini-1.5-pro
AI_MODEL=

# ===== AI API Keys (사용하는 provider 키만 입력) =====
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=
GEMINI_API_KEY=

# ===== 한국투자증권 Open API (KIS Developers) =====
# 발급: https://apiportal.koreainvestment.com → 앱 등록
# 실전투자 앱과 모의투자 앱은 별도로 등록해야 합니다

# 실전투자 (TRADING_MODE=live 일 때 사용)
KIS_APP_KEY=your_live_app_key_here
KIS_APP_SECRET=your_live_app_secret_here
# 계좌번호 10자리 (앞8자리 계좌번호 + 뒤2자리 상품코드, 예: 5012345601)
KIS_ACCOUNT_NUMBER=your_live_account_number_here

# 모의투자 (TRADING_MODE=paper 일 때 사용)
# apiportal.koreainvestment.com → 모의투자 앱 별도 등록 필요
KIS_PAPER_APP_KEY=your_paper_app_key_here
KIS_PAPER_APP_SECRET=your_paper_app_secret_here
KIS_PAPER_ACCOUNT_NUMBER=your_paper_account_number_here

# ===== Telegram Bot =====
# @BotFather 에서 /newbot 으로 토큰 발급
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# @userinfobot 에게 메시지 보내면 Chat ID 확인 가능
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ===== 매매 설정 =====
# paper: 모의투자, live: 실전투자
TRADING_MODE=paper
MAX_BUY_AMOUNT=1000000
MAX_POSITION_SIZE=5000000

# ===== AWS (배포 시 설정) =====
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
