# ─── Kitty Night Mode 환경변수 ───────────────────────────
# Night mode는 기본적으로 .env를 그대로 읽습니다.
# 이 파일(.env.night)은 night 전용으로 값을 덮어쓸 때만 사용합니다.
# (예: night용 별도 KIS 계좌, 다른 AI 모델 등)
#
# 우선순위: .env.night > .env
# KIS/AI/Telegram 키는 .env에 있는 것을 그대로 사용하므로
# 별도 설정이 필요 없으면 이 파일은 만들지 않아도 됩니다.

# ── Night 전용 오버라이드 (필요한 항목만 작성) ──────────────

# AI — night 전용 provider/model로 교체할 때
# NIGHT_AI_PROVIDER=openai          # anthropic | openai | gemini
# NIGHT_AI_MODEL=                   # 비우면 provider 기본값

# KIS 실전 — night 전용 계좌 사용할 때 (없으면 .env의 KIS_APP_KEY 사용)
# NIGHT_KIS_APP_KEY=
# NIGHT_KIS_APP_SECRET=
# NIGHT_KIS_ACCOUNT_NUMBER=         # 10자리

# KIS 모의 — night 전용 모의계좌 사용할 때 (없으면 .env의 KIS_PAPER_* 사용)
# NIGHT_KIS_PAPER_APP_KEY=
# NIGHT_KIS_PAPER_APP_SECRET=
# NIGHT_KIS_PAPER_ACCOUNT_NUMBER=

# ── Night 전용 매매 설정 (반드시 설정) ──────────────────────

NIGHT_TRADING_MODE=paper           # paper | live
NIGHT_MAX_BUY_AMOUNT_USD=700.0     # 1회 최대 매수 (USD)
NIGHT_MAX_POSITION_SIZE_USD=3500.0  # 종목당 최대 보유 (USD)

# 대상 시장 (쉼표 구분)
NIGHT_TARGET_EXCHANGES=NAS,NYS     # NAS=NASDAQ, NYS=NYSE, AMS=AMEX

# 사이클 간격 (초)
NIGHT_CYCLE_SECONDS=900            # 15분
