FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends git && rm -rf /var/lib/apt/lists/*

COPY requirements.night.txt .
RUN pip install --no-cache-dir -r requirements.night.txt

COPY kitty_night/ kitty_night/

RUN mkdir -p night-logs

CMD ["python", "-m", "kitty_night.main"]
